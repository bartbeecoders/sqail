# page-agent UI test runner config
PAGE_AGENT_API_KEY=your-api-key-here
PAGE_AGENT_MODEL=gpt-4o
PAGE_AGENT_BASE_URL=https://api.openai.com/v1

# Delay between test steps in ms (for visual observation, 0 = no delay)
TEST_STEP_DELAY=1000

# Examples:
# OpenAI:       MODEL=gpt-4o        BASE_URL=https://api.openai.com/v1
# OpenRouter:   MODEL=anthropic/claude-sonnet-4  BASE_URL=https://openrouter.ai/api/v1
# Ollama:       MODEL=qwen2.5:7b    BASE_URL=http://localhost:11434/v1
